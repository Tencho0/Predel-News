@{
    var breadcrumbs = ViewBag.Breadcrumbs as List<PredelNews.Core.ViewModels.BreadcrumbItem>;
}

@if (breadcrumbs != null && breadcrumbs.Count > 0)
{
    var encoder = System.Text.Encodings.Web.JavaScriptEncoder.Default;
    var baseUrl = $"{Context.Request.Scheme}://{Context.Request.Host}";

    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "BreadcrumbList",
        "itemListElement": [
            @for (var i = 0; i < breadcrumbs.Count; i++)
            {
                var item = breadcrumbs[i];
                var position = i + 1;
                var url = !string.IsNullOrEmpty(item.Url)
                    ? (item.Url.StartsWith("http://") || item.Url.StartsWith("https://") ? item.Url : baseUrl + item.Url)
                    : null;

                <text>{
                "@@type": "ListItem",
                "position": @position,
                "name": "@Html.Raw(encoder.Encode(item.Name))"@if (url != null){<text>,
                "item": "@Html.Raw(encoder.Encode(url))"</text>}
            }</text>
                if (i < breadcrumbs.Count - 1)
                {
                    <text>,</text>
                }
            }
        ]
    }
    </script>
}
